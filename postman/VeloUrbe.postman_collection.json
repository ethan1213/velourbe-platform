        {
          "name": "Get Active Users by Role ADMIN (ADMIN)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "url": { "raw": "{{auth_url}}/api/users/active/ADMIN", "host": ["{{auth_url}}"], "path": ["api", "users", "active", "ADMIN"] }
          },
          "response": []
        }
      ]
    },
