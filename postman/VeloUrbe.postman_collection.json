                { "key": "latitude", "value": "-33.4372" },
                { "key": "longitude", "value": "-70.6506" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Scooter Location",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_client}}" }],
