# Copia este archivo como .env y ajusta los valores para tu entorno.
# Usado por docker-compose y por los servicios vía variables de entorno.

# Secret compartido por TODOS los servicios para firmar/validar JWT (mínimo 32 chars)
JWT_SECRET=velourbe-secret-de-256-bits-para-jwt-firma-hmac-sha256

# Tiempo de expiración del JWT en milisegundos (3600000 = 1 hora)
JWT_EXPIRATION_MS=3600000

# URLs de servicios (para desarrollo local sin Docker)
USER_AUTH_URL=http://localhost:8081
RENTAL_URL=http://localhost:8082

# Credenciales de PostgreSQL (solo para desarrollo local sin Docker)
DB_USERNAME=postgres
DB_PASSWORD=postgres
